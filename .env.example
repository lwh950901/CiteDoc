# 数据库连接（PostgreSQL + pgvector）
# Docker 本地开发默认值，生产环境请替换
DATABASE_URL="postgres://postgres:postgres@localhost:5432/docqa"

# DeepSeek API Key（AI 对话）
# 注册地址：https://platform.deepseek.com
DEEPSEEK_API_KEY="sk-..."

# SiliconFlow API Key（向量化嵌入）
# 注册地址：https://siliconflow.cn
# 免费模型 BAAI/bge-m3，1024 维向量
SILICONFLOW_API_KEY="sk-..."

# LLM 问答 API（默认 DeepSeek，兼容 OpenAI 接口）
# 注册地址：https://platform.deepseek.com
# 也可替换为其他 OpenAI 兼容服务（GPT-4o、Qwen 等）
LLM_API_KEY="sk-..."
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL="deepseek-chat"
